# kpf defaults to pods; switches to services when the previous arg is -s.
__ktools_kpf() {
  local prev
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  if [[ "$prev" == "-s" ]]; then
    __ktools_services
  else
    __ktools_pods
  fi
}

