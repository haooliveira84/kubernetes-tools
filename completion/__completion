__ktools_current_namespace() {
  local namespace
  namespace="$(kubectl config view -o=jsonpath="{.contexts[?(@.name==\"$(kubectl config current-context)\")].context.namespace}")"
  if [[ -z "${namespace}" ]]; then
    echo default
  else
    echo "$namespace"
  fi
}

__ktools_pods() {
  local cur ns
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  ns="$(__ktools_current_namespace)"
  local items
  items="$(kubectl get pod -n "$ns" --no-headers 2>/dev/null | awk '{print $1}')"
  COMPREPLY=( $( compgen -W "$items" -- "$cur" ) )
}

