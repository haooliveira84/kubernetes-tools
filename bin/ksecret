#!/bin/bash

# Kubernetes Tools - ksecret
# List secrets and decode their values without manual base64.

source __common

ACTION="list"
NAME=""
KEY=""

show_help() {
  echo -e $__title
  echo
  echo -e "- List secrets: ${__style_underlined}ksecret${__style_end}"
  echo -e "- Decode all keys of a secret: ${__style_underlined}ksecret <name>${__style_end}"
  echo -e "- Decode a single key: ${__style_underlined}ksecret <name> <key>${__style_end}"
  echo -e "- Interactive picker: ${__style_underlined}ksecret -s${__style_end}"
  echo -e "- Use another namespace: ${__style_underlined}ksecret -n <ns> ...${__style_end}\n"
}

list_secrets() {
  local ns_flag=""
  if [[ -n "$KTOOLS_NAMESPACE" ]]; then
    ns_flag="-n $KTOOLS_NAMESPACE"
  fi
  # shellcheck disable=SC2086
  kubectl get secrets $ns_flag
}

decode_secret() {
  local name="$1"
  local key="$2"
  local ns_flag=""
  if [[ -n "$KTOOLS_NAMESPACE" ]]; then
    ns_flag="-n $KTOOLS_NAMESPACE"
  fi

  if [[ -n "$key" ]]; then
    # shellcheck disable=SC2086
    local value
    value="$(kubectl get secret $ns_flag "$name" -o jsonpath="{.data.$key}" 2>/dev/null)"
    if [[ -z "$value" ]]; then
      __err "Key \"$key\" not found in secret \"$name\"."
      exit 1
    fi
    echo "$value" | base64 -d
    echo
    return
  fi

  # decode every key
  # shellcheck disable=SC2086
  local keys
  keys=$(kubectl get secret $ns_flag "$name" -o jsonpath='{.data}' 2>/dev/null \
    | tr ',' '\n' | sed -n 's/.*"\([^"]*\)":.*/\1/p')
  if [[ -z "$keys" ]]; then
    __err "Secret \"$name\" not found or has no data."
    exit 1
  fi
  for k in $keys; do
    echo -e "${__style_green}${k}:${__style_end}"
    # shellcheck disable=SC2086
    kubectl get secret $ns_flag "$name" -o jsonpath="{.data.$k}" | base64 -d
    echo
    echo
  done
}

pick_secret() {
  local ns_flag=""
  if [[ -n "$KTOOLS_NAMESPACE" ]]; then
    ns_flag="-n $KTOOLS_NAMESPACE"
  fi
  # shellcheck disable=SC2086,SC2207
  local secrets=($(kubectl get secrets $ns_flag -o name | sed 's|secret/||'))
  if [[ ${#secrets[@]} -eq 0 ]]; then
    __err "No secrets in namespace."
    exit 1
  fi
  local choice
  choice="$(__pick "Select a secret: " "${secrets[@]}")"
  [[ -z "$choice" ]] && exit 1
  decode_secret "$choice"
}

while [ "$1" != "" ]; do
  case $1 in
    -n | --namespace ) shift
      export KTOOLS_NAMESPACE="$1"
      ;;
    -s | --select )
      ACTION="pick"
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
    * )
      if [[ -z "$NAME" ]]; then
        NAME="$1"
        ACTION="decode"
      else
        KEY="$1"
      fi
      ;;
  esac
  shift
done

case "$ACTION" in
  pick ) pick_secret ;;
  decode ) decode_secret "$NAME" "$KEY" ;;
  * ) list_secrets ;;
esac
