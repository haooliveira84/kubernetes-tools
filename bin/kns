source __common

show_help() {
  echo -e $__title
  echo
  echo -e "- List current and all namespaces: ${__style_underlined}kns${__style_end}"
  echo -e "- Interactive selection: ${__style_underlined}kns [-s|--select]${__style_end}"
  echo -e "- Switch to specified namespace: ${__style_underlined}kns [namespace]${__style_end}\n"
}

list_namespaces() {
  local ctx ns
  ctx="$(__current_context)"
  ns="$(__current_namespace)"
  echo -e "Current Context:   ${__style_green}${ctx}${__style_end}"
  echo -e "Current Namespace: ${__style_green}${ns}${__style_end}"
  echo
  echo "All namespaces:"
  kubectl get ns | awk -v ns="$ns" '{
    if ($1 == ns) printf "\033[32m%s\033[0m\n", $0;
    else print $0;
  }'
}

select_ns() {
  echo -e "Setting default namespace:\n"
  local namespaces
  # shellcheck disable=SC2207
  namespaces=($(kubectl get ns -o name | sed 's|namespace/||'))
  if [[ ${#namespaces[@]} -eq 0 ]]; then
    __err "No namespaces found."
    exit 1
  fi
  local choice
  choice="$(__pick "Select a namespace: " "${namespaces[@]}")"
  [[ -z "$choice" ]] && exit 1
  update_context "$choice"
}

update_context() {
  local ns="$1"
  if [[ -z "$ns" ]]; then
    __err "No namespace specified."
    exit 1
  fi
  echo -e "\nSetting \"$ns\" as default namespace in current context...\n"
  kubectl config set-context "$(__current_context)" --namespace="$ns"
}

while [ "$1" != "" ]; do
  case $1 in
    -s | --select )
      select_ns
      exit 0
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
    * )
      update_context "$1"
      exit 0
      ;;
  esac
  shift
done

if [ $# -eq 0 ]; then list_namespaces; fi
