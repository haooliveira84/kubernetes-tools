#!/bin/bash

# Kubernetes Tools - Copyright (C) 2017 Shawn Wang
# https://github.com/shawnxlw/kubernetes-tools
#
# You may use, distribute or modify this software under the terms of the MIT license.

BUSY_BOX_URL="https://busybox.net/downloads/binaries/1.27.1-i686/busybox"
BUSY_BOX_SHA="b51b9328eb4e60748912e1c1867954a5cf7e9d5294781cae59ce225ed110523c"
BUSY_BOX_DIR="/tmp/${BUSY_BOX_SHA}"
BUSY_BOX_BIN="${BUSY_BOX_DIR}/busybox"

source __common

CONTAINER=""

show_help() {
  echo -e $__title
  echo
  echo -e "- Copy common CLI tools (busybox) to a container: ${__style_underlined}kcopy [pod_name]${__style_end}"
  echo -e "- Pick container explicitly: ${__style_underlined}kcopy -c <container> [pod_name]${__style_end}"
  echo -e "- Use another namespace: ${__style_underlined}kcopy -n <ns> [pod_name]${__style_end}"
  echo
  echo -e "${__style_dim}Consider using 'kdebug' instead — it uses kubectl debug${__style_end}"
  echo -e "${__style_dim}with an ephemeral container (no host modifications).${__style_end}\n"
}

verify_busybox() {
  [[ -f "$BUSY_BOX_BIN" ]] || return 1
  echo "${BUSY_BOX_SHA}  ${BUSY_BOX_BIN}" | shasum -ca 256 - >/dev/null 2>&1
}

get_busybox() {
  if verify_busybox; then
    return 0
  fi
  __info "Downloading busybox..."
  mkdir -p "$BUSY_BOX_DIR"
  if ! curl -fsSLo "$BUSY_BOX_BIN" "$BUSY_BOX_URL"; then
    __err "Failed to download busybox from $BUSY_BOX_URL"
    rm -f "$BUSY_BOX_BIN"
    return 1
  fi
  if ! verify_busybox; then
    __err "busybox checksum mismatch. Removing bad file."
    rm -f "$BUSY_BOX_BIN"
    return 1
  fi
}

copy_tools() {
  local pod="$1"

  local ns_flag=""
  local namespace
  if [[ -n "$KTOOLS_NAMESPACE" ]]; then
    ns_flag="-n $KTOOLS_NAMESPACE"
    namespace="$KTOOLS_NAMESPACE"
  else
    namespace="$(__current_namespace)"
  fi

  # shellcheck disable=SC2086
  if ! kubectl get pod $ns_flag "$pod" >/dev/null 2>&1; then
    __err "Pod \"$pod\" not found in namespace \"$namespace\"."
    exit 1
  fi

  get_busybox || exit 1

  local container="$CONTAINER"
  if [[ -z "$container" ]]; then
    container="$(__pick_container "$pod")" || exit 1
  fi

  echo -e "\nCopying busybox to $container...\n"
  # shellcheck disable=SC2086
  kubectl cp $ns_flag "$BUSY_BOX_BIN" "$namespace/$pod:/tmp" -c "$container"
  # shellcheck disable=SC2086
  kubectl exec $ns_flag "$pod" -c "$container" -ti -- sh -c "chmod 755 /tmp/busybox && /tmp/busybox --install /usr/bin"

  echo -e "\nGetting you a shell in $container...\n"
  # shellcheck disable=SC2086
  kubectl exec $ns_flag "$pod" -c "$container" -ti -- bash 2>/dev/null \
    || kubectl exec $ns_flag "$pod" -c "$container" -ti -- sh
}

POD=""

while [ "$1" != "" ]; do
  case $1 in
    -n | --namespace ) shift
      export KTOOLS_NAMESPACE="$1"
      ;;
    -c | --container ) shift
      CONTAINER="$1"
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
    * )
      POD="$1"
      ;;
  esac
  shift
done

if [[ -z "$POD" ]]; then
  show_help
  exit 0
fi

copy_tools "$POD"
