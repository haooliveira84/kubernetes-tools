source __common

show_help() {
  echo -e $__title
  echo
  echo -e "- List current and all contexts: ${__style_underlined}kctx${__style_end}"
  echo -e "- Switch to specified context: ${__style_underlined}kctx [context]${__style_end}"
  echo -e "- Interactive selection: ${__style_underlined}kctx [-s|--select]${__style_end}"
  echo -e "- Switch back to previous context: ${__style_underlined}kctx [-|--last]${__style_end}\n"
}

show_context() {
  local current
  current="$(__current_context)"
  echo -e "Current Context: \"${__style_green}${current}${__style_end}\"\n"
  echo "All Contexts:"
  kubectl config get-contexts
}

switch_context() {
  local target="$1"
  local current
  current="$(__current_context)"
  if [[ -z "$target" ]]; then
    __err "No context specified."
    exit 1
  fi
  if [[ "$target" == "$current" ]]; then
    __info "Already on \"$target\"."
    exit 0
  fi
  echo "Switching from \"$current\" to \"$target\""
  kubectl config use-context "$target"
}

select_context() {
  local contexts
  # shellcheck disable=SC2207
  contexts=($(kubectl config get-contexts -o name))
  if [[ ${#contexts[@]} -eq 0 ]]; then
    __err "No contexts found in kubeconfig."
    exit 1
  fi
  local choice
  choice="$(__pick "Select a context: " "${contexts[@]}")"
  [[ -z "$choice" ]] && exit 1
  switch_context "$choice"
}

switch_last() {
  local last
  last="$(kubectl config get-contexts -o name | grep -v "^$(__current_context)$" | head -n1)"
  if [[ -z "$last" ]]; then
    __err "No other context to switch to."
    exit 1
  fi
  switch_context "$last"
}

while [ "$1" != "" ]; do
  case $1 in
    -c | --context ) shift
      switch_context "$1"
      exit 0
      ;;
    -s | --select )
      select_context
      exit 0
      ;;
    - | --last )
      switch_last
      exit 0
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
    * )
      switch_context "$1"
      exit 0
      ;;
  esac
  shift
done

if [ $# -eq 0 ]; then show_context; fi
