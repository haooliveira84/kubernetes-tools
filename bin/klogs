source __common

FOLLOW=""
TAIL=""
SINCE=""
PREVIOUS=""
ALL_CONTAINERS=""
CONTAINER=""
TIMESTAMPS=""

show_help() {
  echo -e $__title
  echo
  echo -e "- Get logs of a selected container: ${__style_underlined}klogs [pod_name]${__style_end}"
  echo -e "- Follow logs: ${__style_underlined}klogs -f [pod_name]${__style_end}"
  echo -e "- Tail N lines: ${__style_underlined}klogs --tail N [pod_name]${__style_end}"
  echo -e "- Since duration (e.g. 5m, 1h): ${__style_underlined}klogs --since 10m [pod_name]${__style_end}"
  echo -e "- Previous container logs: ${__style_underlined}klogs -p [pod_name]${__style_end}"
  echo -e "- All containers in pod: ${__style_underlined}klogs -a [pod_name]${__style_end}"
  echo -e "- Add timestamps: ${__style_underlined}klogs -t [pod_name]${__style_end}"
  echo -e "- Pick container explicitly: ${__style_underlined}klogs -c <container> [pod_name]${__style_end}"
  echo -e "- Use another namespace: ${__style_underlined}klogs -n <ns> [pod_name]${__style_end}\n"
}

get_logs() {
  local pod="$1"

  local ns_flag=""
  if [[ -n "$KTOOLS_NAMESPACE" ]]; then
    ns_flag="-n $KTOOLS_NAMESPACE"
  fi

  local args=()
  [[ -n "$FOLLOW" ]] && args+=("-f")
  [[ -n "$TAIL" ]] && args+=("--tail=$TAIL")
  [[ -n "$SINCE" ]] && args+=("--since=$SINCE")
  [[ -n "$PREVIOUS" ]] && args+=("--previous")
  [[ -n "$TIMESTAMPS" ]] && args+=("--timestamps")

  if [[ -n "$ALL_CONTAINERS" ]]; then
    echo -e "\nLogs of all containers in $pod...\n"
    # shellcheck disable=SC2086
    kubectl logs $ns_flag "$pod" --all-containers=true "${args[@]}"
    return
  fi

  local container="$CONTAINER"
  if [[ -z "$container" ]]; then
    container="$(__pick_container "$pod")" || exit 1
  fi
  if [[ -z "$container" ]]; then
    __err "No container selected."
    exit 1
  fi

  echo -e "\nLogs of $container in $pod...\n"
  # shellcheck disable=SC2086
  kubectl logs $ns_flag "$pod" -c "$container" "${args[@]}"
}

POD=""

while [ "$1" != "" ]; do
  case $1 in
    -n | --namespace ) shift
      export KTOOLS_NAMESPACE="$1"
      ;;
    -c | --container ) shift
      CONTAINER="$1"
      ;;
    -f | --follow )
      FOLLOW="1"
      ;;
    --tail ) shift
      TAIL="$1"
      ;;
    --tail=* )
      TAIL="${1#*=}"
      ;;
    --since ) shift
      SINCE="$1"
      ;;
    --since=* )
      SINCE="${1#*=}"
      ;;
    -p | --previous )
      PREVIOUS="1"
      ;;
    -a | --all-containers )
      ALL_CONTAINERS="1"
      ;;
    -t | --timestamps )
      TIMESTAMPS="1"
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
    * )
      POD="$1"
      ;;
  esac
  shift
done

if [[ -z "$POD" ]]; then
  show_help
  exit 0
fi

get_logs "$POD"
