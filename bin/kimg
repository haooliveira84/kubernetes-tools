#!/bin/bash

# Kubernetes Tools - kimg
# List container images in use, grouped by pod.

source __common

ALL_NS=""
UNIQUE=""

show_help() {
  echo -e $__title
  echo
  echo -e "- List images in current namespace: ${__style_underlined}kimg${__style_end}"
  echo -e "- All namespaces: ${__style_underlined}kimg -a${__style_end}"
  echo -e "- Unique images only: ${__style_underlined}kimg -u${__style_end}"
  echo -e "- Use another namespace: ${__style_underlined}kimg -n <ns>${__style_end}\n"
}

run() {
  local args=()
  if [[ -n "$ALL_NS" ]]; then
    args+=("--all-namespaces")
  elif [[ -n "$KTOOLS_NAMESPACE" ]]; then
    args+=("-n" "$KTOOLS_NAMESPACE")
  fi

  if [[ -n "$UNIQUE" ]]; then
    kubectl get pods "${args[@]}" -o jsonpath='{range .items[*]}{range .spec.containers[*]}{.image}{"\n"}{end}{end}' \
      | sort -u
    return
  fi

  if [[ -n "$ALL_NS" ]]; then
    kubectl get pods "${args[@]}" -o jsonpath='{range .items[*]}{.metadata.namespace}{"\t"}{.metadata.name}{"\t"}{range .spec.containers[*]}{.image}{","}{end}{"\n"}{end}' \
      | column -t -s $'\t'
  else
    kubectl get pods "${args[@]}" -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{range .spec.containers[*]}{.image}{","}{end}{"\n"}{end}' \
      | column -t -s $'\t'
  fi
}

while [ "$1" != "" ]; do
  case $1 in
    -n | --namespace ) shift
      export KTOOLS_NAMESPACE="$1"
      ;;
    -a | --all )
      ALL_NS="1"
      ;;
    -u | --unique )
      UNIQUE="1"
      ;;
    -h | --help )
      show_help
      exit 0
      ;;
    -* )
      __err "Unknown flag: $1"
      show_help
      exit 1
      ;;
  esac
  shift
done

run
